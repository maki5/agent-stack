{
  "name": "agent-stack",
  "version": "0.1.1",
  "description": "Reusable OpenCode agent workflow setup for any tech stack",
  "type": "module",
  "bin": {
    "agent-stack": "./dist/agent-stack.js"
  },
  "scripts": {
    "start": "bun run bin/agent-stack.ts",
    "dev": "bun run --watch bin/agent-stack.ts",
    "build": "bun build bin/agent-stack.ts --outfile dist/agent-stack.js --target bun --external kleur",
    "prepublishOnly": "bun run build"
  },
  "files": [
    "dist/",
    "agents/",
    "skills/",
    "tools/",
    "templates/"
  ],
  "dependencies": {
    "kleur": "^4.1.5"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
