{
  "$schema": "https://opencode.ai/config.json",
  "instructions": [
    "AGENTS.md",
    ".github/instructions/git-workflow.instructions.md"{{#if_flag "has_backend" profile}},
    ".github/instructions/go-backend.instructions.md"{{/if_flag}}{{#if_flag "has_frontend" profile}},
    ".github/instructions/typescript-frontend.instructions.md"{{/if_flag}}{{#if_flag "has_database" profile}},
    ".github/instructions/database.instructions.md"{{/if_flag}},
    ".github/instructions/testing.instructions.md",
    ".github/instructions/post-implementation.instructions.md",
    ".github/instructions/tester-workflow.instructions.md",
    ".github/instructions/commit-guidelines.instructions.md"
  ],
  "model": "{{profile.model_complex}}",
  "agent": {
    "implementer": {
      "description": "Coordinator agent for implementing features. Profile flags: has_backend={{profile.has_backend}}, has_frontend={{profile.has_frontend}}, has_infra={{profile.has_infra}}, has_database={{profile.has_database}}. Flow: research → ui-designer (mandatory, GATE: approve mockups if any) → designer (uses approved mockups as UI spec) → GATE: design approval → plan → plan-reviewer → GATE: plan approval{{#if_flag "has_backend" profile}} → backend-developer{{/if_flag}}{{#if_flag "has_infra" profile}} → infra-developer{{/if_flag}}{{#if_flag "has_frontend" profile}} → frontend-developer{{/if_flag}} → tester → reviewer → cleaner → formatter. MANDATORY SKILLS: Load immediately upon startup using the skill tool - 'git-workflow', 'code-review', 'self-healing'. PERFORMANCE STATS: Track and report final implementation summary with agent flow, time, and tokens.",
      "mode": "primary",
      "model": "{{profile.model_complex}}",
      "temperature": 0.3,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "skill": true
      }
    },
    "debugger": {
      "description": "Coordinator agent for diagnosing and fixing bugs. Profile flags: has_backend={{profile.has_backend}}, has_frontend={{profile.has_frontend}}, has_infra={{profile.has_infra}}. Flow: research → identify root cause → plan → developer → tester → reviewer → cleaner → formatter. MANDATORY SKILLS: Load immediately upon startup using the skill tool - 'git-workflow', 'code-review', 'self-healing'. PERFORMANCE STATS: Track and report final diagnostic summary with agent flow, time, and tokens.",
      "mode": "primary",
      "model": "{{profile.model_complex}}",
      "temperature": 0.2,
      "tools": {
        "write": false,
        "edit": false,
        "bash": true,
        "skill": true
      }
    },
    "researcher": {
      "description": "Lead researcher that researches system architecture, patterns, and dependencies. Uses caching to avoid redundant research. Project stack: {{profile.languages}} / {{profile.frameworks}}. MANDATORY SKILLS: Load 'three-layer-testing', 'code-review' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.3,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "write": true,
        "skill": true
      }
    },
    "designer": {
      "description": "Creates design documents with C4 diagrams, data flows, sequence diagrams, testing strategies, and API design. MANDATORY SKILLS: Load 'code-review' immediately upon startup. Also load 'c4-architecture' and 'mermaid-diagrams' from the global ~/.agents/skills/ if available.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.3,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "write": true,
        "skill": true
      }
    },
    "ui-designer": {
      "description": "Creates visual UI mockups for frontend features. Generates SVG mockups and component specifications. MANDATORY SKILLS: Load 'ui-ux-pro-max', 'web-design-guidelines' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.3,
      "tools": {
        "read": true,
        "write": true,
        "glob": true,
        "bash": true,
        "skill": true
      }
    },
    "planner": {
      "description": "Analyzes design documents and creates implementation plans. Project stack: {{profile.languages}} / {{profile.frameworks}}. MANDATORY SKILLS: Load 'three-layer-testing' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.2,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "skill": true
      }
    },
    "plan-reviewer": {
      "description": "Reviews implementation plans created by the planner for completeness, correctness, and alignment with the design. Returns findings to coordinator for planner to fix. NOT accessible from CLI — subagent only. MANDATORY SKILLS: Load 'three-layer-testing', 'code-review' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.1,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "skill": true
      }
    },
    "coder": {
      "description": "Coordinates code implementation by delegating to{{#if_flag "has_backend" profile}} backend-developer,{{/if_flag}}{{#if_flag "has_infra" profile}} infra-developer (always after backend — self-assesses whether infra changes are needed),{{/if_flag}}{{#if_flag "has_frontend" profile}} frontend-developer.{{/if_flag}} MANDATORY SKILLS: Load 'three-layer-testing' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.15,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "skill": true
      }
    },{{#if_flag "has_backend" profile}}
    "backend-developer": {
      "description": "Implements backend code following design. Tech: {{#if profile.impl_agents.backend}}{{profile.impl_agents.backend.tech}}{{else}}custom{{/if}}. Commits after each logical layer: models/repository → service → handler. MANDATORY SKILLS: Load relevant backend skills immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.15,
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "skill": true
      }
    },{{/if_flag}}{{#if_flag "has_infra" profile}}
    "infra-developer": {
      "description": "Checks whether a feature needs infrastructure changes and implements them if needed. Tech: {{#if profile.impl_agents.infra}}{{profile.impl_agents.infra.tech}}{{else}}custom{{/if}}. Always called after backend-developer. NOT accessible from CLI — subagent only. MANDATORY SKILLS: Load relevant infra skills immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.15,
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "skill": true
      }
    },{{/if_flag}}{{#if_flag "has_frontend" profile}}
    "frontend-developer": {
      "description": "Implements frontend code following design. Tech: {{#if profile.impl_agents.frontend}}{{profile.impl_agents.frontend.tech}}{{else}}custom{{/if}}. Commits after each logical layer: service → components → pages. MANDATORY SKILLS: Load 'three-layer-testing', 'ui-ux-pro-max' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.15,
      "tools": {
        "read": true,
        "write": true,
        "edit": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "skill": true
      }
    },{{/if_flag}}
    "tester": {
      "description": "Writes and runs tests, validates implementation. Test command: {{profile.test.unit_cmd}}{{#if profile.test.e2e_tool}}. E2E tool: {{profile.test.e2e_tool}}{{/if}}. MANDATORY SKILLS: Load 'three-layer-testing', 'e2e-testing-patterns', 'self-healing' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_fast}}",
      "temperature": 0.2,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true
      }
    },
    "reviewer": {
      "description": "Reviews code in 2 passes + risk analysis for quality and correctness. MANDATORY SKILLS: Load 'code-review', 'self-healing' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_complex}}",
      "temperature": 0.1,
      "tools": {
        "read": true,
        "glob": true,
        "grep": true,
        "bash": true,
        "skill": true
      }
    },
    "cleaner": {
      "description": "Removes unused code, dead files, and artifacts. MANDATORY SKILLS: Load 'code-review' immediately upon startup for cleanup identification.",
      "mode": "subagent",
      "model": "{{profile.model_fast}}",
      "temperature": 0.05,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true
      }
    },
    "formatter": {
      "description": "Runs formatters, linters, and validation tools. MANDATORY SKILLS: Load 'self-healing' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_fast}}",
      "temperature": 0.05,
      "tools": {
        "write": true,
        "edit": true,
        "bash": true,
        "skill": true
      }
    },
    "commiter": {
      "description": "Summarizes work and creates commits. MANDATORY SKILLS: Load 'git-workflow' immediately upon startup.",
      "mode": "subagent",
      "model": "{{profile.model_fast}}",
      "temperature": 0.1,
      "tools": {
        "bash": true,
        "skill": true
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    },
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push *": "ask"
    }
  }
}
